    \"JSONnodeData\": \"{\\n    \\\"m_Id\\\": 2,\\n    \\\"m_DisplayName\\\": \\\"Color\\\",\\n    \\\"m_SlotType\\\": 1,\\n    \\\"m_Priority\\\": 2147483647,\\n    \\\"m_Hidden\\\": false,\\n    \\\"m_ShaderOutputName\\\": \\\"Color\\\",\\n    \\\"m_StageCapability\\\": 3,\\n    \\\"m_Value\\\": {\\n        \\\"x\\\": 0.0,\\n        \\\"y\\\": 0.0,\\n        \\\"z\\\": 0.0\\n    },\\n    \\\"m_DefaultValue\\\": {\\n        \\\"x\\\": 0.0,\\n        \\\"y\\\": 0.0,\\n        \\\"z\\\": 0.0\\n    },\\n    \\\"m_Labels\\\": [\\n        \\\"X\\\",\\n        \\\"Y\\\",\\n        \\\"Z\\\"\\n    ]\\n}\"\n        },\n        {\n            \"typeInfo\": {\n                \"fullName\": \"UnityEditor.ShaderGraph.Vector3MaterialSlot\"\n            },\n            \"JSONnodeData\": \"{\\n    \\\"m_Id\\\": 0,\\n    \\\"m_DisplayName\\\": \\\"WorldPos\\\",\\n    \\\"m_SlotType\\\": 0,\\n    \\\"m_Priority\\\": 2147483647,\\n    \\\"m_Hidden\\\": false,\\n    \\\"m_ShaderOutputName\\\": \\\"WorldPos\\\",\\n    \\\"m_StageCapability\\\": 3,\\n    \\\"m_Value\\\": {\\n        \\\"x\\\": 0.0,\\n        \\\"y\\\": 0.0,\\n        \\\"z\\\": 0.0\\n    },\\n    \\\"m_DefaultValue\\\": {\\n        \\\"x\\\": 0.0,\\n        \\\"y\\\": 0.0,\\n        \\\"z\\\": 0.0\\n    },\\n    \\\"m_Labels\\\": [\\n        \\\"X\\\",\\n        \\\"Y\\\",\\n        \\\"Z\\\"\\n    ]\\n}\"\n        }\n    ],\n    \"m_PreviewExpanded\": true,\n    \"m_SourceType\": 1,\n    \"m_FunctionName\": \"LWRPLightingFunction_float\",\n    \"m_FunctionSource\": \"Assets/Funtions\",\n    \"m_FunctionBody\": \"#ifdef LIGHTWEIGHT_LIGHTING_INCLUDED\\r\\n    Light mainLight = GetMainLight();\\r\\n    Color = mainLight.color;\\r\\n    Direction = mainLight.direction;\\r\\n    //Color = float3(0.0, 0.0,1.0);\\r\\n#else\\r\\n   \\r\\n    Direction = float3(-0.5, 0.5, -0.5);\\r\\n    Color = float3(1.0, 0.0, 0.0);\\r\\n#endif\\r\\n\\r\\nfloat4 shadowCoord;\\r\\n\\r\\n#ifdef _SHADOWS_ENABLED\\r\\n\\r\\n\\t#if SHADOWS_SCREEN\\r\\n\\t\\tfloat4 clipPos = TransformWorldToHClip(WorldPos);\\r\\n\\t\\tshadowCoord = ComputeShadowCoord(clipPos);\\r\\n\\t#else\\r\\n\\t\\tshadowCoord = TransformWorldToShadowCoord(WorldPos);\\r\\n\\t#endif\\r\\n\\r\\n    #ifdef LIGHTWEIGHT_LIGHTING_INCLUDED\\r\\n\\t    mainLight.attenuation = MainLightRealtimeShadowAttenuation(shadowCoord);\\r\\n        Attenuation = mainLight.attenuation;\\r\\n    #else\\r\\n        Attenuation = MainLightRealtimeShadowAttenuation(shadowCoord);\\r\\n    #endif\\r\\n\\r\\n#else // _SHADOWS_ENABLED\\r\\n    Attenuation = 0;\\r\\n#endif\"\n}"
